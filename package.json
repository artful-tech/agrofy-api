{
  "name": "agrofy-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "dotenv -e .env.development -- npx nodemon --watch src/ -e ts --exec \"ts-node -r tsconfig-paths/register src/server.ts\"",
    "prod": "dotenv -e .env -- npx nodemon --watch src/ -e ts --exec \"ts-node -r tsconfig-paths/register src/server.ts\"",
    "migrate:dev": "dotenv -e .env.development -- npx prisma migrate dev",
    "migrate:dev:deploy": "dotenv -e .env.development -- npx prisma migrate deploy",
    "migrate:dev:reset": "dotenv -e .env.development -- npx prisma migrate reset",
    "migrate:prod": "npx prisma migrate deploy",
    "migrate:prod:reset": "dotenv -e .env -- npx prisma migrate reset",
    "prisma:generate": "dotenv -e .env.development -- npx prisma generate",
    "seed:dev": "dotenv -e .env.development -- npx prisma db seed",
    "seed:prod": "dotenv -e .env -- npx prisma db seed",
    "studio:dev": "dotenv -e .env.development -- npx prisma studio",
    "compile": "npx tsc && copyfiles -u 1 src/views/pages/*.html dist/src/",
    "start": "node ./dist/src/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "openmeteo": "^1.2.3",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "copyfiles": "^2.4.1",
    "dotenv-cli": "^11.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
