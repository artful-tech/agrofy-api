{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./",
    "outDir": "./dist/",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@prisma/gen-client": ["./prisma/generated/prisma/client"]
    }
  },
  "ts-node": { "transpileOnly": true }
}