generator client {
    provider = "prisma-client-js" // Corrigido para o provider padrão
}

datasource db {
    provider = "postgresql"
}

// --- ENUMS PARA PERFORMANCE E INTEGRIDADE ---

enum Role {
    ADMIN
    MANAGER
    WORKER
    OWNER
}

enum SeasonStatus {
    PLANTED
    GROWING
    HARVESTED
    CANCELLED
}

enum Currency {
    BRL
    MUMBUCA
    DOLAR
    EURO
}

enum LogCategory {
    WEATHER
    PEST
    EMERGENCY
    OBSERVATION
}

enum TransactionType {
    INCOME // Receita (Venda de safra, subsídio)
    EXPENSE // Despesa (Sementes, mão de obra)
}

// --- TABELAS ---

model User {
    id       String @id @default(uuid())
    email    String @unique @db.VarChar(255)
    password String @db.VarChar(35)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    people People?

    @@map("users")
}

model People {
    id        String  @id @default(uuid())
    name      String  @db.VarChar(150)
    cellphone String? @db.VarChar(20)
    role      Role    @default(WORKER) // Alterado para Enum
    photo     String? @db.Text
    userId    String  @unique

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
    farms   PeopleOnFarms[]
    manager Manager?

    @@map("peoples")
}

model Manager {
    id       String @id @default(uuid())
    peopleId String @unique

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    people   People    @relation(fields: [peopleId], references: [id])
    transactions Transaction[]
    finance Finance?

    @@map("managers")
}

model Address {
    id           String  @id @default(uuid())
    street       String? @db.VarChar(60)
    number       Int?
    complement   String? @db.VarChar(40)
    neighborhood String? @db.VarChar(100)
    city         String  @db.VarChar(100)
    state        String  @db.VarChar(50)
    country      String  @default("Brasil") @db.VarChar(50)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    farm Farm?

    @@map("addresses")
}

model Farm {
    id          String  @id @default(uuid())
    name        String  @db.VarChar(150)
    totalArea   Float
    unity       String  @db.VarChar(10)
    resume      String? @db.VarChar(255)
    photo       String? @db.Text
    addressId   String  @unique
    observation String? @db.VarChar(255)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    peoples     PeopleOnFarms[]
    plots       Plot[]
    address     Address         @relation(fields: [addressId], references: [id])
    inventories InventoryItem[]

    @@map("farms")
}

model PeopleOnFarms {
    peopleId String
    farmId   String

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    people People @relation(fields: [peopleId], references: [id])
    farm   Farm   @relation(fields: [farmId], references: [id])

    @@id([peopleId, farmId])
    @@map("people_on_farms")
}

model Plot {
    id          String  @id @default(uuid())
    name        String  @db.VarChar(100)
    area        Float
    unity       String  @db.VarChar(10)
    soilType    String? @db.VarChar(40)
    farmId      String
    photo       String? @db.Text
    observation String? @db.VarChar(255)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    farm    Farm     @relation(fields: [farmId], references: [id])
    seasons Season[]

    @@map("plots")
}

model Crop {
    id            String  @id @default(uuid())
    name          String  @db.VarChar(100)
    variety       String? @db.VarChar(100)
    photo         String? @db.Text
    daysToHarvest Int
    observation   String? @db.VarChar(255)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    seasons Season[]

    @@map("crops")
}

model Season {
    id        String       @id @default(uuid())
    status    SeasonStatus @default(PLANTED) // Alterado para Enum
    plantedAt DateTime     @default(now())
    harvestAt DateTime?
    photo     String?      @db.Text
    plotId    String
    cropId    String

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    plot Plot       @relation(fields: [plotId], references: [id])
    crop Crop       @relation(fields: [cropId], references: [id])
    logs FieldLog[]
    transactions Transaction[]

    @@map("seasons")
}

model FieldLog {
    id          String      @id @default(uuid())
    description String      @db.VarChar(255)
    category    LogCategory // Alterado para Enum
    date        DateTime    @default(now())
    seasonId    String

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

    @@map("field_logs")
}

model InventoryItem {
    id       String  @id @default(uuid())
    name     String  @db.VarChar(100)
    category String? @db.VarChar(50)
    quantity Float
    unit     String  @db.VarChar(20) // Ex: KG, UN, L
    minStock Float   @default(0)
    farmId   String

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    farm Farm @relation(fields: [farmId], references: [id])

    @@map("inventory_items")
}

model Transaction {
    id          String          @id @default(uuid())
    description String          @db.VarChar(255)
    amount      Decimal         @db.Decimal(12, 2)
    type        TransactionType
    currency    Currency        @default(BRL)
    date        DateTime        @default(now())
    category    String?         @db.VarChar(100)
    managerId   String
    seasonId    String?

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    manager Manager @relation(fields: [managerId], references: [id])
    season  Season? @relation(fields: [seasonId], references: [id])

    @@map("transactions")
}

model Finance {
    id        String   @id @default(uuid())
    balance   Decimal  @db.Decimal(15, 2) // Maior precisão para balanços totais
    currency  Currency @default(BRL)
    managerId String @unique

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    manager Manager @relation(fields: [managerId], references: [id])

    @@map("finances")
}
